# Copy this file to terraform.tfvars and fill in the values.
# NEVER commit terraform.tfvars — it contains secrets.

# ---- cluster target ----
namespace          = "conduit"
kubeconfig_path    = "~/.kube/config"
kubeconfig_context = "my-cluster-context"   # leave empty for current-context

# ---- image ----
image_repo = "registry.example.com/conduit"
image_tag  = "1.0.0"

# ---- scaling ----
replicas         = 2
hpa_min_replicas = 2
hpa_max_replicas = 10

# ---- resources ----
cpu_request    = "100m"
cpu_limit      = "500m"
memory_request = "128Mi"
memory_limit   = "512Mi"

# ---- app config ----
port      = 8080
log_level = "INFO"
flask_env = "production"

# ---- ingress ----
ingress_host       = "conduit.example.com"
ingress_class_name = "nginx"
ingress_tls_secret = "conduit-tls"

# ---- secrets (sensitive — keep out of version control) ----
database_url   = "postgresql+psycopg2://conduit_user:changeme@postgres-svc:5432/conduit"
secret_key     = "change-me-random-64-char-string"
jwt_secret_key = "change-me-another-random-64-char-string"
