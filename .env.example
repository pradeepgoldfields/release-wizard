# ─────────────────────────────────────────────────────────────────────────────
# Conduit — environment variable reference
#
# Copy this file to .env (local dev) or supply values via K8s ConfigMap/Secret.
# Lines starting with # are comments. Never commit real secrets to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────

HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO        # DEBUG | INFO | WARNING | ERROR
DEBUG=false           # Set to true for local dev only

# ── Database ──────────────────────────────────────────────────────────────────

# Local dev (SQLite — no setup required)
DATABASE_URL=sqlite:///instance/conduit.db

# Production (PostgreSQL)
# DATABASE_URL=postgresql+psycopg2://conduit:password@db-host:5432/conduit

# PostgreSQL connection pool (ignored for SQLite)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# ── Authentication ────────────────────────────────────────────────────────────

# REQUIRED — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production

JWT_EXPIRY_HOURS=8    # How long a JWT token stays valid

# ── LDAP (optional — leave blank to disable LDAP authentication) ──────────────

LDAP_URL=ldaps://ldap.example.com
LDAP_BIND_DN=cn=svc-conduit,ou=ServiceAccounts,dc=example,dc=com
LDAP_BIND_PASSWORD=
LDAP_BASE_DN=dc=example,dc=com
LDAP_USER_SEARCH_BASE=ou=People,dc=example,dc=com
LDAP_GROUP_SEARCH_BASE=ou=Groups,dc=example,dc=com

# ── Redis (optional — used for caching; app works without it) ─────────────────

REDIS_URL=redis://localhost:6379/0

# ── AI Assistant ──────────────────────────────────────────────────────────────

# Required to enable the AI chat feature.
# Get a free key at https://console.groq.com
# Can also be set via Administration → Settings in the UI.
GROQ_API_KEY=

# ── Storage ───────────────────────────────────────────────────────────────────

# Where audit PDF reports are written inside the container.
# Must be a writable path; use a PersistentVolumeClaim mount in K8s.
AUDIT_STORAGE_PATH=/tmp/audit-reports
